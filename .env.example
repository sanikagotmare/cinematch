# Copy this file to .env and fill in your values
# Never commit .env to version control

APP_NAME=CineMatch API
DEBUG=false

# Paths
MOVIES_CSV=data/tmdb_5000_movies.csv
CREDITS_CSV=data/tmdb_5000_credits.csv
CHROMA_PERSIST_DIR=.chromadb

# Embedding model (downloaded automatically on first run)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# TMDB API — get your free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=YOUR_TMDB_API_KEY_HERE
TMDB_REGION=IN

# Cache TTL in seconds (default: 1 hour)
CACHE_TTL_SECONDS=3600
