# ── Secrets — NEVER commit these ──────────────────────────────────────────────
.env
*.pem
*.key

# ── Kaggle data — too large for GitHub (100 MB limit) ─────────────────────────


# ── ChromaDB — generated by ingestion, not source code ────────────────────────
.chromadb/
.chromadb_test/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Sentence Transformers model cache ─────────────────────────────────────────
# The model is downloaded automatically on first run (~80 MB)
.cache/
/models/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
